{
  "schemaVersion": 1,
  "id": "esp",
  "version": "${version}",
  "name": "ESP",
  "description": "Label-based entity highlighting. Scans nearby floating text for configured patterns and outlines the matching mob.",
  "authors": ["NoName_"],
  "license": "LGPL-3",
  "icon": "assets/icon.png",
  "contact": {
    "sources": "https://github.com/noname-mods/ESP"
  },
  "environment": "client",
  "entrypoints": {
    "client": ["com.esp.EspMod"],
    "modmenu": ["com.esp.modmenu.EspModMenuPlugin"]
  },
  "mixins": ["esp.mixins.json"],
  "depends": {
    "fabricloader": ">=0.19.0",
    "minecraft": "~26.1",
    "java": ">=25",
    "fabric-api": "*",
    "playerapi": ">=1.12.0",
    "yet_another_config_lib_v3": "*"
  },
  "suggests": {
    "modmenu": "*"
  }
}
